msgstr "コマンドライン引数が多すぎます(先頭は\"%s\")"

#: pg_waldump.c:1274
#, c-format
msgid "unnecessary command-line arguments specified with tar archive (first is \"%s\")"
msgstr "tarアーカイブとともに，不要なコマンドライン引数が指定されています (先頭は\"%s\")"

#: pg_waldump.c:1309
#, c-format
msgid "start WAL location %X/%08X is not inside file \"%s\""
