msgstr " 8 *  2kB open_sync writes"

#: pg_test_fsync.c:457
msgid "16 *  1kB open_sync writes"
msgstr "16 *  1kB open_sync writes"

#: pg_test_fsync.c:511
#, c-format
msgid ""
"\n"
"Test if fsync on non-write file descriptor is honored:\n"
