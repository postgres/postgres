#, c-format
msgid "pg_dump failed on database \"%s\", exiting"
msgstr "データベース\"%s\"のダンプが失敗しました、終了します"

#: pg_dumpall.c:2129
#, c-format
msgid "could not re-open the output file \"%s\": %m"
msgstr "出力ファイル\"%s\"を再オープンできませんでした: %m"

