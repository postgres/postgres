"შეცდომების შესახებ მიწერეთ: %s\n"

#: pg_waldump.c:925
#, c-format
msgid "%s home page: <%s>\n"
msgstr "%s-ის საწყისი გვერდია: <%s>\n"

#: pg_waldump.c:1027
#, c-format
msgid "no arguments specified"
msgstr "არგუმენტები მითითებული არაა"

