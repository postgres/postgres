#: commands/wait.c:56
#, c-format
msgid "%s can only be executed as a top-level statement"
msgstr "%s は最上位の文としてのみ実行可能です"

#: commands/wait.c:58
#, c-format
msgid "WAIT FOR cannot be used within a function, procedure, or DO block."
msgstr "WAIT FOR は関数、プロシージャ、または DO ブロック内では使用できません。"

#: commands/wait.c:107
#, c-format
msgid "invalid timeout value: \"%s\""
msgstr "不正なタイムアウト値: \"%s\""

#: commands/wait.c:122
#, c-format
msgid "timeout value is out of range"
msgstr "タイムアウト値が範囲外です"

