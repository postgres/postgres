msgstr "--follow はtarアーカイブの読み取り時にはサポートされません"

#: pg_waldump.c:1408
#, c-format
msgid "out of memory while allocating a WAL reading processor"
msgstr "WAL読み取り機構でのメモリ割り当てに中にメモリ不足"

#: pg_waldump.c:1424
#, c-format
msgid "could not find a valid record after %X/%08X: %s"
