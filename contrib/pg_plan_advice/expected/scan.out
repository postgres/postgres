SET LOCAL pg_plan_advice.advice = 'INDEX_ONLY_SCAN(nothing whatsoever)';
EXPLAIN (COSTS OFF, PLAN_ADVICE) SELECT a FROM scan_table WHERE a = 1;
                       QUERY PLAN                        
---------------------------------------------------------
 Index Only Scan using scan_table_pkey on scan_table
