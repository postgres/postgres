#: pg_walsummary.c:267
#, c-format
msgid "Usage:\n"
msgstr "使用方法:\n"

#: pg_walsummary.c:268
#, c-format
msgid "  %s [OPTION]... FILE...\n"
msgstr "  %s [オプション]... ファイル...\n"

#: pg_walsummary.c:269
#, c-format
msgid ""
"\n"
"Options:\n"
msgstr ""
"\n"
"オプション:\n"

#: pg_walsummary.c:270
#, c-format
msgid "  -i, --individual          list block numbers individually, not as ranges\n"
msgstr "  -i, --individual          ブロック番号を領域としてではなく、個別に表示する\n"

#: pg_walsummary.c:271
#, c-format
msgid "  -q, --quiet               don't print anything, just parse the files\n"
msgstr "  -q, --quiet               何も表示せずに、ただファイルをパースする\n"

#: pg_walsummary.c:272
#, c-format
msgid "  -V, --version             output version information, then exit\n"
msgstr "  -V, --version             バージョン情報を表示して終了\n"

#: pg_walsummary.c:273
#, c-format
msgid "  -?, --help                show this help, then exit\n"
msgstr "  -?, --help                このヘルプを表示して終了\n"

#: pg_walsummary.c:275
#, c-format
msgid ""
"\n"
"Report bugs to <%s>.\n"
msgstr ""
"\n"
"バグは<%s>に報告してください。\n"

