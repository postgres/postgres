msgstr "ビュー\"%2$s\"の列\"%1$s\"は更新できません"

#: rewrite/rewriteHandler.c:3471
#, c-format
msgid "cannot merge into column \"%s\" of view \"%s\""
msgstr "ビュー\"%2$s\"の列\"%1$s\"への統合はできません"

